@using Tyuiu.Courses.Programming.Core.Constants
<!DOCTYPE html>
<html lang="ru">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"]</title>

	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css?v=1.0" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
	<link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css">
	<link rel="stylesheet" href="~/Tyuiu.Courses.Programming.Api.styles.css?v=1.0" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/mainStyle.css" />
	<link rel="stylesheet" href="~/css/showAlertsStyle.css" />
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
	<link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.css">

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Handjet:wght@100..900&display=swap?v=1.0" rel="stylesheet">

</head>
<body class="d-flex flex-column min-vh-100">
	<header class="bg-white pos-sticky-top">
		<nav class="navbar navbar-expand-lg">
			<div class="container-lg container-fluid mx-4 mx-lg-auto">
				<a class="navbar-brand" asp-area="" asp-controller="Courses" asp-action="Learn">
					<img class="object-fit-contain rounded" src="~/LogoTiu.jpg" alt="Logo" height="80">
				</a>
				
				@* tablet *@
				<span class="ms-auto d-flex">
					@if (User?.Identity?.IsAuthenticated ?? false)
					{
						<ul class="navbar-nav d-flex flex-row gap-3">
							<li class="nav-item order-1 d-lg-none d-sm-flex d-none">
								<a class="btn btn-outline-secondary rounded-3" role="button" style="--bs-btn-hover-bg: Gainsboro; --bs-btn-active-bg: Silver; --bs-btn-border-color: LightGray;
								" asp-area="" asp-controller="PersonalAccount" asp-action="StudentPersonalAccount" aria-current="page">
									<i class="bi bi-person-circle fs-5 text-primary"></i><span class="visually-hidden">(current)</span>
								</a>
							</li>

							<li class="nav-item order-0 d-flex d-sm-flex d-lg-none me-3 me-sm-0 me-lg-0">
								<button class="btn btn-outline-secondary position-relative rounded-3" type="button" style="--bs-btn-hover-bg: Gainsboro; --bs-btn-active-bg: Silver;
--bs-btn-border-color: LightGray;"
								data-bs-toggle="offcanvas" data-bs-target="#offcanvasNotifications" aria-controls="offcanvasNotifications">
									<i class="bi bi-bell fs-5 text-black"></i>
									<span id="layoutNotificationCount"
										  class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger"
										  style="@(ViewBag.NotificationsCount > 0 ? "display: block;" : "display: none;")">
										@(ViewBag.NotificationsCount > 0 ? ViewBag.NotificationsCount : "")
									</span>
								</button>
							</li>
						</ul>
					}
					<ul class="navbar-nav d-flex flex-row d-lg-none d-sm-flex d-none ms-5 me-3">
						<li class="nav-item order-2">
							<partial name="_LoginPartial" />
						</li>
					</ul>
				</span>

				<button class="navbar-toggler d-lg-none border-0" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavId" aria-controls="collapsibleNavId"
				aria-expanded="false" aria-label="Toggle navigation" style="--bs-navbar-toggler-focus-width: 0.1rem;">
					<span class="navbar-toggler-icon"></span>
				</button>

				<div class="collapse navbar-collapse justify-content-end" id="collapsibleNavId">
					@* Mobile *@
					<span class="d-flex mt-3 mt-sm-0 mt-lg-0 mb-3 mb-sm-0 mb-lg-0">
						@if (User != null && User.Identity.IsAuthenticated)
						{
							<ul class="navbar-nav d-flex flex-row gap-3 d-lg-none d-sm-none">
								<li class="nav-item order-1">
									<a class="btn btn-outline-secondary rounded-3" role="button" style="--bs-btn-hover-bg: Gainsboro; --bs-btn-active-bg: Silver; --bs-btn-border-color: LightGray;
									" asp-area="" asp-controller="PersonalAccount" asp-action="StudentPersonalAccount" aria-current="page">
										<i class="bi bi-person-circle fs-5 text-primary"></i><span class="visually-hidden">(current)</span>
									</a>
								</li>
							</ul>
						}
						<ul class="navbar-nav d-flex flex-row ms-auto d-lg-none d-sm-none">
							<li class="nav-item order-2">
								<partial name="_LoginPartial" />
							</li>
						</ul>
					</span>

					@if (User != null && User.Identity.IsAuthenticated)
					{
						<ul class="navbar-nav d-flex gap-2 me-auto">
							<li class="nav-item">
								<a class="nav-link" asp-controller="Courses" asp-action="Learn">Мои курсы</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-controller="Courses" asp-action="FAQ">FAQ</a>
							</li>
							@if (User.FindFirst("UserRoles").Value != Roles.Student)
							{

								<li class="nav-item">
									<a class="nav-link" asp-controller="Courses" asp-action="Manage">Редактор курсов</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" asp-controller="Disciplines" asp-action="Index">Дисциплины</a>
								</li>

								@if (User.FindFirst("UserRoles").Value == Roles.Admin)
								{
									<li class="nav-item">
										<a class="nav-link" asp-controller="Users" asp-action="Index">Пользователи</a>
									</li>
									<li class="nav-item">
										<a class="nav-link" asp-controller="Groups" asp-action="Index">Группы</a>
									</li>
									<li class="nav-item">
										<a class="nav-link" asp-controller="Features" asp-action="Index">Функции</a>
									</li>
								}
							}
						</ul>

						<ul class="navbar-nav gap-3 d-none d-lg-flex d-sm-none">
							<li class="nav-item order-1">
								<a class="btn btn-outline-secondary rounded-3" role="button" style="--bs-btn-hover-bg: Gainsboro; --bs-btn-active-bg: Silver; --bs-btn-border-color: LightGray;
								" asp-area="" asp-controller="PersonalAccount" asp-action="StudentPersonalAccount" aria-current="page">
									<i class="bi bi-person-circle fs-5 text-primary"></i><span class="visually-hidden">(current)</span>
								</a>
							</li>

							<li class="nav-item order-0">
								<button class="btn btn-outline-secondary position-relative rounded-3" type="button" style="--bs-btn-hover-bg: Gainsboro; --bs-btn-active-bg: Silver;
--bs-btn-border-color: LightGray;"
								data-bs-toggle="offcanvas" data-bs-target="#offcanvasNotifications" aria-controls="offcanvasNotifications">
									<i class="bi bi-bell fs-5 text-black"></i>
									<span id="layoutNotificationCount"
										  class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger"
										  style="@(ViewBag.NotificationsCount > 0 ? "display: block;" : "display: none;")">
										@(ViewBag.NotificationsCount > 0 ? ViewBag.NotificationsCount : "")
									</span>
								</button>
							</li>
						</ul>

					}
					<span class="d-none d-lg-flex d-sm-none">
						<partial name="_LoginPartial" />
					</span>
				</div>

			</div>
		</nav>
	</header>
	<div>
		<main role="main" class="pb-3">
			@RenderBody()
			@Html.AntiForgeryToken()
			<script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
			<script src="~/js/showToastScript.js"></script>
			@* @await Component.InvokeAsync("Notifications") *@
		</main>
	</div>

	<button type="button"
			class="btn btn-primary rounded-circle shadow d-none align-items-center justify-content-center position-fixed"
			id="btn-scroll-top"
			onclick="scrollToTop()"
			style="bottom: 30px; right: 30px; width: 45px; height: 45px;">
		<i class="bi bi-chevron-up"></i>
	</button>
	@* <footer class="border-top text-muted mt-auto">
	<div class="container py-3">
	&copy; 2023 - Tyuiu.Courses.Programming.Api - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
	</div>
	</footer> *@
	<script>
		function scrollToTop() {
			window.scrollTo({
				top: 0,
				behavior: 'smooth'
			});
		}

		// Показывать/скрывать кнопку при скролле
		window.addEventListener('scroll', function() {
			const scrollTopBtn = document.querySelector('#btn-scroll-top');
			if (window.scrollY > 300) {
				scrollTopBtn.classList.remove('d-none');
				scrollTopBtn.classList.add('d-flex');
			} else {
				scrollTopBtn.classList.remove('d-flex');
				scrollTopBtn.classList.add('d-none');
			}
		});
	</script>
	<script src="~/js/requestsResultHandler.js"></script>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js?v=1.0" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
	<script src="https://code.jquery.com/jquery-3.7.1.min.js?v=1.0" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
	<script src="https://code.jquery.com/ui/1.13.3/jquery-ui.min.js?v=1.0" integrity="sha256-sw0iNNXmOJbQhYFuC9OF2kOlD5KQKe1y5lfBn4C9Sjg=" crossorigin="anonymous"></script>

	<script src="~/js/scrollBeforePosition.js"></script>
	@await RenderSectionAsync("Scripts", required: false)
	@* <Suspense>
		@await Component.InvokeAsync("InfoNotifications")
	</Suspense>

	@if (Html.IsFeatureEnabled("Snowfall")) {
	 	@await Html.PartialAsync("_Snowfall");
	}; *@

</body>
</html>