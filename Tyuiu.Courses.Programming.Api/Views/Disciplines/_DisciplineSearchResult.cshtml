@using Tyuiu.Courses.Programming.Application.Features.Disciplines.GetDisciplinesPaginated
@model DisciplineSearchModel

<div class="card">
    <div class="card-header fs-5" style="min-height: 55px">
        <div class="d-flex align-items-center justify-content-between">
            <span>Дисциплины</span>
            <button type="button" class="btn btn-outline-primary shadow-sm rounded-circle btn-sm me-auto ms-2" data-bs-toggle="modal" data-bs-target="#createDisciplineModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="28" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2" />
                </svg>
            </button>
            <span class="col-6">
                <span class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Начните вводить дисциплину" aria-label="Search"
                           id="DisciplineSearch" value="@Model.Pagination.SearchTerm">
                </span>
            </span>
        </div>
    </div>
    <ul class="list-group" id="list">
        @foreach (var discipline in Model.Disciplines)
        {
            <li class="list-group-item" style="min-height: 49px">
                <div class="d-flex align-items-center">
                    <div class="me-auto">
                        <a asp-controller="Themes" asp-action="Manage" asp-route-id="@discipline.Id" class="stretched-link">@discipline.Name</a>
                        <div class="fw-light mt-2">
                            Автор: @(discipline.IsCurrentUserAuthor ? "Вы" : discipline.AuthorName)
                        </div>
                    </div>

                    <div class="d-flex ms-auto gap-3 z-1">
                        @if (discipline.IsCurrentUserAuthor)
                        {
                            <button class="btn btn-outline-primary shadow-sm btn-sm" data-bs-toggle="modal" data-bs-target="#editDisciplineNameModal" data-item-name="@discipline.Name" data-item-id="@discipline.Id">
                                <i class="bi bi-pencil fs-5"></i>
                            </button>
                        }
                        <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#cloneDisciplineModal" data-item-name="@discipline.Name" data-item-id="@discipline.Id">
                            <i class="bi bi-copy fs-5"></i>
                        </button>
                        @if (!discipline.HasCourses && discipline.IsCurrentUserAuthor)
                        {
                            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteDisciplineModal" data-item-name="@discipline.Name" data-item-id="@discipline.Id">
                                <i class="bi bi-trash fs-5"></i>
                            </button>
                        }
                    </div>
                </div>
            </li>
        }
    </ul>
</div>
@await Html.PartialAsync("_Pagination", Model.Pagination)